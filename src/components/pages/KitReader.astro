---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  entry: CollectionEntry<'kit'>;
  // Where the "back" link points: the kit index or the examples gallery.
  variant?: 'kit' | 'examples';
}

const { lang, entry, variant = 'kit' } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

const { Content } = await render(entry);

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

// Diagram components are embedded in-body via MDX at the right point in each kit
// document's narrative (see docs/DIAGRAM_COMPONENTS.md §5) — not injected here.

const backHref =
  variant === 'examples' ? `${prefix}/examples` : `${prefix}/kit`;
const backLabel =
  variant === 'examples' ? t.examplesPage.backToGallery : t.kitPage.backToIndex;
const baseSegment = variant === 'examples' ? 'examples' : 'kit';

// Surface a few well-known passthrough metadata fields when present.
const data = entry.data as Record<string, unknown>;
const metaBadges = [
  typeof data.usage === 'string'
    ? { label: 'Usage', value: data.usage as string }
    : null,
  typeof data.agent === 'string'
    ? { label: 'Agent', value: data.agent as string }
    : null,
  typeof data.stack === 'string'
    ? { label: 'Stack', value: data.stack as string }
    : null,
  typeof data.support === 'string'
    ? { label: 'Support', value: data.support as string }
    : null,
].filter((b): b is { label: string; value: string } => b !== null);

const techArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  description: entry.data.description,
  url: `${siteUrl}${prefix}/${baseSegment}/${slugOf(entry.id)}`,
};
---

<MainLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <JsonLd slot="head" data={techArticleSchema} />
  <div class="main-container py-16 md:py-20">
    <article class="max-w-3xl">
      <a
        href={backHref}
        class="kicker inline-flex items-center hover:opacity-80"
        style="color: var(--color-secondary);"
      >
        &larr; {backLabel}
      </a>

      {
        metaBadges.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {metaBadges.map((badge) => (
              <span
                class="inline-flex items-center gap-1 border px-3 py-1 text-xs"
                style="border-color: var(--color-line); color: var(--color-muted);"
              >
                <span class="font-semibold" style="color: var(--color-ink);">
                  {badge.label}:
                </span>
                {badge.value}
              </span>
            ))}
          </div>
        )
      }

      <div
        class="prose prose-lg max-w-none dark:prose-invert prose-headings:scroll-mt-24 prose-a:text-secondary mt-6"
      >
        <Content />
      </div>
    </article>
  </div>
</MainLayout>
