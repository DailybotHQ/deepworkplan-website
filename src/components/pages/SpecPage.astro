---
import { getCollection } from 'astro:content';
import Kicker from '@/components/editorial/Kicker.astro';
import Lead from '@/components/editorial/Lead.astro';
import Rule from '@/components/editorial/Rule.astro';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import {
  getUrlPrefix,
  type Language,
  stripEntryLangPrefix as slugOf,
} from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const s = t.specPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

const docs = (await getCollection('spec'))
  .filter((d) => d.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

// Group by section, preserving the order documents first appear.
const sections: { name: string; docs: typeof docs }[] = [];
for (const doc of docs) {
  const name = doc.data.section ?? 'General';
  let group = sections.find((g) => g.name === name);
  if (!group) {
    group = { name, docs: [] };
    sections.push(group);
  }
  group.docs.push(doc);
}

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: s.title,
  itemListElement: docs.map((doc, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: doc.data.title,
    url: `${siteUrl}${prefix}/spec/${slugOf(doc.id)}`,
  })),
};
---

<MainLayout lang={lang} title={s.meta.title} description={s.meta.description}>
  <JsonLd slot="head" data={itemListSchema} />

  <article class="main-container py-16 md:py-24">
    <header class="max-w-3xl">
      <Kicker>{s.eyebrow}</Kicker>
      <h1
        class="font-display mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
        style="color: var(--color-ink);"
      >
        {s.title}
      </h1>
      <Lead class="mt-6">{s.intro}</Lead>
    </header>

    <Rule class="my-12" />

    <div class="space-y-12">
      {
        sections.map((group) => (
          <section>
            <Kicker>{group.name}</Kicker>
            <ul class="mt-6 space-y-4">
              {group.docs.map((doc) => (
                <li>
                  <a
                    href={`${prefix}/spec/${slugOf(doc.id)}`}
                    class="group block border p-5 transition hover:opacity-90"
                    style="border-color: var(--color-line);"
                  >
                    <h2
                      class="font-display text-lg font-semibold"
                      style="color: var(--color-ink);"
                    >
                      {doc.data.title}
                    </h2>
                    <p class="mt-1 leading-relaxed" style="color: var(--color-muted);">
                      {doc.data.description}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </article>
</MainLayout>
