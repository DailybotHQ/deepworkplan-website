---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Kicker from '@/components/editorial/Kicker.astro';
import Rule from '@/components/editorial/Rule.astro';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  entry: CollectionEntry<'spec'>;
}

const { lang, entry } = Astro.props;
const t = getTranslations(lang);
const s = t.specPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

const { Content, headings } = await render(entry);
// In-page TOC: top-level (h2) headings only.
const toc = headings.filter((h) => h.depth === 2);

// Sequential prev/next across the spec documents in reading order.
const documents = (await getCollection('spec'))
  .filter((c) => c.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const index = documents.findIndex((c) => c.id === entry.id);
const prev = index > 0 ? documents[index - 1] : null;
const next = index < documents.length - 1 ? documents[index + 1] : null;

// Diagram components are embedded in-body via MDX at the right point in each spec
// document's narrative (see docs/DIAGRAM_COMPONENTS.md §5) — not injected here.

const techArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  description: entry.data.description,
  url: `${siteUrl}${prefix}/spec/${slugOf(entry.id)}`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${siteUrl}${prefix}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: s.title,
      item: `${siteUrl}${prefix}/spec`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: entry.data.title,
      item: `${siteUrl}${prefix}/spec/${slugOf(entry.id)}`,
    },
  ],
};
---

<MainLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <JsonLd slot="head" data={techArticleSchema} />
  <JsonLd slot="head" data={breadcrumbSchema} />
  <div class="main-container py-16 md:py-20">
    <a
      href={`${prefix}/spec`}
      class="kicker inline-flex items-center hover:opacity-80"
      style="color: var(--color-secondary);"
    >
      &larr; {s.backToIndex}
    </a>
    <div class="mt-6 lg:grid lg:grid-cols-[1fr_16rem] lg:gap-12">
      <article class="min-w-0 max-w-3xl">
        <div
          class="prose prose-lg max-w-none dark:prose-invert prose-headings:scroll-mt-24 prose-a:text-secondary"
        >
          <Content />
        </div>

        <Rule class="mt-16 mb-8" />

        <nav
          class="flex flex-col justify-between gap-4 sm:flex-row"
          aria-label="Spec document"
        >
          {
            prev ? (
              <a
                href={`${prefix}/spec/${slugOf(prev.id)}`}
                class="group flex-1 border p-4 transition hover:opacity-90"
                style="border-color: var(--color-line);"
              >
                <span class="kicker">&larr; {s.prev}</span>
                <span
                  class="font-display mt-1 block font-semibold"
                  style="color: var(--color-ink);"
                >
                  {prev.data.title}
                </span>
              </a>
            ) : (
              <span class="flex-1" />
            )
          }
          {
            next ? (
              <a
                href={`${prefix}/spec/${slugOf(next.id)}`}
                class="group flex-1 border p-4 text-right transition hover:opacity-90"
                style="border-color: var(--color-line);"
              >
                <span class="kicker justify-end">{s.next} &rarr;</span>
                <span
                  class="font-display mt-1 block font-semibold"
                  style="color: var(--color-ink);"
                >
                  {next.data.title}
                </span>
              </a>
            ) : (
              <span class="flex-1" />
            )
          }
        </nav>
      </article>
      {
        toc.length > 0 && (
          <aside class="mt-12 lg:mt-0">
            <div class="lg:sticky lg:top-24">
              <Kicker>{s.tocTitle}</Kicker>
              <ul class="mt-3 space-y-2 border-l" style="border-color: var(--color-line);">
                {toc.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="-ml-px block border-l-2 border-transparent pl-3 text-sm transition hover:border-secondary hover:text-secondary"
                      style="color: var(--color-muted);"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )
      }
    </div>
  </div>
</MainLayout>
