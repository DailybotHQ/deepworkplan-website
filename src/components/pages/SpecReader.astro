---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  entry: CollectionEntry<'spec'>;
}

const { lang, entry } = Astro.props;
const t = getTranslations(lang);
const s = t.specPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

const { Content, headings } = await render(entry);
// In-page TOC: top-level (h2) headings only.
const toc = headings.filter((h) => h.depth === 2);

const techArticleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: entry.data.title,
  description: entry.data.description,
  url: `${siteUrl}${prefix}/spec/${slugOf(entry.id)}`,
};
---

<MainLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <JsonLd slot="head" data={techArticleSchema} />
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-20">
    <a
      href={`${prefix}/spec`}
      class="inline-flex items-center text-sm font-medium text-secondary hover:underline mb-6"
    >
      &larr; {s.backToIndex}
    </a>
    <div class="lg:grid lg:grid-cols-[1fr_16rem] lg:gap-12">
      <article class="min-w-0 max-w-3xl">
        <div class="prose prose-lg prose-slate max-w-none dark:prose-invert prose-headings:scroll-mt-24 prose-a:text-secondary">
          <Content />
        </div>
      </article>
      {
        toc.length > 0 && (
          <aside class="mt-12 lg:mt-0">
            <div class="lg:sticky lg:top-24">
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300 mb-3">
                {s.tocTitle}
              </p>
              <ul class="space-y-2 border-l border-gray-200 dark:border-gray-700">
                {toc.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class="block border-l-2 border-transparent -ml-px pl-3 text-sm text-gray-600 dark:text-gray-300 hover:border-secondary hover:text-secondary transition-colors"
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )
      }
    </div>
  </div>
</MainLayout>
