---
import Kicker from '@/components/editorial/Kicker.astro';
import Lead from '@/components/editorial/Lead.astro';
import Rule from '@/components/editorial/Rule.astro';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import {
  CANONICAL_INIT_MD_PATH,
  getCanonicalInitMdUrl,
  getUrlPrefix,
  type Language,
} from '@/lib/i18n';
import { getCanonicalInitMarkdown } from '@/lib/init-prompt';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const p = t.initPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';
// The bootstrap endpoint is always the root, English /init.md (canonical
// first-class agent content) — never a localized variant.
const mdHref = CANONICAL_INIT_MD_PATH;
// Full absolute URL shown next to the "Copy init.md" button (always the
// canonical English endpoint).
const mdUrl = getCanonicalInitMdUrl(siteUrl || undefined);
// "Copy init.md" copies the full canonical ENGLISH init.md (what /init.md
// serves), regardless of page language. Button labels are shared with the home
// hero so the call-to-action reads identically everywhere.
const initMarkdown = await getCanonicalInitMarkdown();
const copyLabel = t.home.hero.copyLabel;
const copiedLabel = t.home.hero.copiedLabel;

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: p.meta.title,
  description: p.meta.description,
  url: `${siteUrl}${prefix}/init`,
  step: p.steps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: step.title,
    text: step.description,
  })),
};
---

<MainLayout lang={lang} title={p.meta.title} description={p.meta.description}>
  <JsonLd slot="head" data={howToSchema} />

  <article class="main-container py-16 md:py-24">
    <header class="max-w-3xl">
      <Kicker>{p.eyebrow}</Kicker>
      <h1
        class="font-display mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
        style="color: var(--color-ink);"
      >
        {p.title}
      </h1>
      <Lead class="mt-6">{p.intro}</Lead>
    </header>

    <Rule class="my-12" />

    {/* Give this to your agent — prominent call-out */}
    <section
      class="max-w-3xl border-l-2 pl-6"
      style="border-color: var(--color-secondary);"
    >
      <Kicker>{p.handoffTitle}</Kicker>
      <p class="mt-4 text-lg leading-relaxed" style="color: var(--color-muted);">
        {p.handoffBody}
      </p>
      <div
        class="mt-5 flex flex-wrap items-center justify-between gap-3 rounded-sm border px-4 py-3"
        style="border-color: var(--color-secondary);"
      >
        <a
          href={mdHref}
          class="min-w-0 break-all font-mono text-sm underline underline-offset-4 transition hover:opacity-80"
          style="color: var(--color-secondary);">{mdUrl}</a
        >
        <button
          type="button"
          class="copy-btn kicker inline-flex cursor-pointer items-center gap-1.5 rounded-sm px-2 py-1 transition enabled:hover:opacity-80 disabled:cursor-default disabled:opacity-70"
          style="color: var(--color-secondary);"
          data-copy={initMarkdown}
          data-label={copyLabel}
          data-copied={copiedLabel}
          data-lang={lang}
          aria-label={copyLabel}
        >
          {copyLabel}
        </button>
      </div>
      <p class="mt-4">
        <a
          href={mdHref}
          class="font-mono text-sm underline underline-offset-4 hover:opacity-80"
          style="color: var(--color-secondary);"
        >
          {p.handoffMdLabel} → {mdHref}
        </a>
      </p>
    </section>

    <Rule class="my-12" />

    <section class="max-w-3xl">
      <Kicker>{p.whatTitle}</Kicker>
      <div class="mt-6 space-y-5">
        {
          p.whatBody.map((paragraph) => (
            <p class="text-lg leading-relaxed" style="color: var(--color-muted);">
              {paragraph}
            </p>
          ))
        }
      </div>
    </section>

    <Rule class="my-12" />

    <section class="max-w-3xl">
      <Kicker>{p.sequenceTitle}</Kicker>
      <ol class="mt-8 space-y-12">
        {
          p.steps.map((step, i) => (
            <li class="border-t pt-5" style="border-color: var(--color-secondary);">
              <span
                class="font-display text-3xl font-bold"
                style="color: var(--color-secondary);"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <h2
                class="font-display mt-2 text-2xl font-semibold"
                style="color: var(--color-ink);"
              >
                {step.title}
              </h2>
              <p class="mt-3 text-lg leading-relaxed" style="color: var(--color-muted);">
                {step.description}
              </p>
              {step.commands && (
                <div class="mt-5 space-y-3">
                  {step.commands.map((command, ci) => (
                    <div>
                      {ci > 0 && <p class="kicker mb-2">{p.orLabel}</p>}
                      <div
                        class="overflow-hidden border"
                        style="border-color: var(--color-line);"
                      >
                        <div
                          class="border-b px-3 py-1.5"
                          style="border-color: var(--color-line); background-color: var(--color-gray-100);"
                        >
                          <span class="kicker">{p.codeLabel}</span>
                        </div>
                        <pre class="overflow-x-auto px-3 py-3" style="background-color: var(--color-gray-100);"><code class="font-mono text-xs leading-relaxed" style="color: var(--color-ink);">{command}</code></pre>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </li>
          ))
        }
      </ol>
    </section>

    <Rule class="my-12" />

    <section class="max-w-3xl">
      <Kicker>{p.outcomeTitle}</Kicker>
      <p
        class="font-display mt-6 border-l-2 pl-4 text-xl italic"
        style="border-color: var(--color-secondary); color: var(--color-ink);"
      >
        {p.outcome}
      </p>
    </section>

    <Rule class="my-12" />

    <section>
      <Kicker>{p.nextStepsTitle}</Kicker>
      <div class="mt-6 flex flex-wrap gap-4">
        {
          p.nextSteps.map((step) => (
            <a
              href={`${prefix}${step.href}`}
              class="inline-flex items-center rounded-sm border px-5 py-3 font-semibold transition hover:opacity-80"
              style="border-color: var(--color-line); color: var(--color-ink);"
            >
              {step.label}
            </a>
          ))
        }
      </div>
    </section>
  </article>
</MainLayout>

<script>
  import { EVENTS, trackEvent } from '@/lib/analytics';

  const COPY_FEEDBACK_MS = 2000;

  // Progressive enhancement: copy the full init.md prompt to the clipboard.
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    let busy = false;

    btn.addEventListener('click', async () => {
      if (busy || btn.disabled) return;

      const text = btn.dataset.copy ?? '';
      const label = btn.dataset.label ?? 'Copy init.md';
      const copied = btn.dataset.copied ?? 'Copied';

      busy = true;
      try {
        await navigator.clipboard.writeText(text);
        trackEvent(EVENTS.COPY_INIT, {
          source: 'init_page',
          lang: btn.dataset.lang ?? 'en',
        });
        btn.disabled = true;
        btn.textContent = copied;
        btn.setAttribute('aria-label', copied);
        window.setTimeout(() => {
          btn.disabled = false;
          btn.textContent = label;
          btn.setAttribute('aria-label', label);
          busy = false;
        }, COPY_FEEDBACK_MS);
      } catch {
        busy = false;
      }
    });
  });
</script>
