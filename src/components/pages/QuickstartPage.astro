---
import Kicker from '@/components/editorial/Kicker.astro';
import Lead from '@/components/editorial/Lead.astro';
import Rule from '@/components/editorial/Rule.astro';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const q = t.quickstartPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: q.meta.title,
  description: q.meta.description,
  url: `${siteUrl}${prefix}/quickstart`,
  step: q.steps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: step.title,
    text: step.description,
  })),
};
---

<MainLayout lang={lang} title={q.meta.title} description={q.meta.description}>
  <JsonLd slot="head" data={howToSchema} />

  <article class="main-container py-16 md:py-24">
    <header class="max-w-3xl">
      <Kicker>{q.eyebrow}</Kicker>
      <h1
        class="font-display mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
        style="color: var(--color-ink);"
      >
        {q.title}
      </h1>
      <Lead class="mt-6">{q.intro}</Lead>
    </header>

    <Rule class="my-12" />

    <section class="max-w-3xl">
      <Kicker>{q.sequenceTitle}</Kicker>
      <ol class="mt-8 space-y-12">
        {
          q.steps.map((step, i) => (
            <li class="border-t pt-5" style="border-color: var(--color-secondary);">
              <span
                class="font-display text-3xl font-bold"
                style="color: var(--color-secondary);"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <h2
                class="font-display mt-2 text-2xl font-semibold"
                style="color: var(--color-ink);"
              >
                {step.title}
              </h2>
              <p class="mt-3 text-lg leading-relaxed" style="color: var(--color-muted);">
                {step.description}
              </p>
              {step.commands && (
                <div class="mt-5 space-y-3">
                  {step.commands.map((command, ci) => (
                    <div>
                      {ci > 0 && (
                        <p class="kicker mb-2">{q.orLabel}</p>
                      )}
                      <div
                        class="overflow-hidden border"
                        style="border-color: var(--color-line);"
                      >
                        <div
                          class="border-b px-3 py-1.5"
                          style="border-color: var(--color-line); background-color: var(--color-gray-100);"
                        >
                          <span class="kicker">{q.codeLabel}</span>
                        </div>
                        <pre class="overflow-x-auto px-3 py-3" style="background-color: var(--color-gray-100);"><code class="font-mono text-xs leading-relaxed" style="color: var(--color-ink);">{command}</code></pre>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </li>
          ))
        }
      </ol>
    </section>

    <Rule class="my-12" />

    <section class="max-w-3xl">
      <Kicker>{q.outcomeTitle}</Kicker>
      <p
        class="font-display mt-6 border-l-2 pl-4 text-xl italic"
        style="border-color: var(--color-secondary); color: var(--color-ink);"
      >
        {q.outcome}
      </p>
    </section>

    <Rule class="my-12" />

    <section>
      <Kicker>{q.nextStepsTitle}</Kicker>
      <div class="mt-6 flex flex-wrap gap-4">
        {
          q.nextSteps.map((step) => (
            <a
              href={`${prefix}${step.href}`}
              class="inline-flex items-center rounded-sm border px-5 py-3 font-semibold transition hover:opacity-80"
              style="border-color: var(--color-line); color: var(--color-ink);"
            >
              {step.label}
            </a>
          ))
        }
      </div>
    </section>
  </article>
</MainLayout>
