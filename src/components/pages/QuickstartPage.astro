---
import JsonLd from '@/components/JsonLd.astro';
import PageHero from '@/components/pages/PageHero.astro';
import PageSection from '@/components/pages/PageSection.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const q = t.quickstartPage;
const qs = t.home.quickstart;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: q.meta.title,
  description: q.meta.description,
  url: `${siteUrl}${prefix}/quickstart`,
  step: qs.paths.map((path, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: path.title,
    text: path.note,
  })),
};
---

<MainLayout lang={lang} title={q.meta.title} description={q.meta.description}>
  <JsonLd slot="head" data={howToSchema} />
  <PageHero title={q.title} subtitle={q.eyebrow} description={q.intro} />

  <PageSection background="white">
    <div class="grid gap-6 lg:grid-cols-3 max-w-5xl mx-auto">
      {
        qs.paths.map((path) => (
          <article
            class:list={[
              'flex flex-col gap-4 rounded-xl border p-6',
              path.highlight
                ? 'border-indigo-300 bg-indigo-50/50 dark:border-indigo-700 dark:bg-indigo-950/20'
                : 'border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900',
            ]}
          >
            <div class="flex items-center justify-between gap-2">
              <span class="font-mono text-xs font-semibold uppercase tracking-wider text-gray-600 dark:text-gray-300">
                {path.tag}
              </span>
              {path.highlight && (
                <span class="rounded-full bg-indigo-600 px-2.5 py-0.5 text-[0.65rem] font-bold uppercase tracking-wide text-white dark:bg-indigo-500">
                  {qs.recommended}
                </span>
              )}
            </div>
            <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100">{path.title}</h2>
            <p class="text-sm text-gray-600 dark:text-gray-300">{path.tagline}</p>
            <div class="mt-auto overflow-hidden rounded-lg border border-gray-200 bg-gray-950 dark:border-gray-800">
              <div class="border-b border-white/10 px-3 py-1.5">
                <span class="font-mono text-[0.65rem] uppercase tracking-wide text-gray-600 dark:text-gray-300">
                  {qs.codeLabel}
                </span>
              </div>
              <pre class="overflow-x-auto px-3 py-3"><code class="font-mono text-xs leading-relaxed text-gray-100">{path.command}</code></pre>
            </div>
            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-300">{path.note}</p>
          </article>
        ))
      }
    </div>
  </PageSection>

  <PageSection background="gray" title={q.nextStepsTitle}>
    <div class="flex flex-wrap gap-4 justify-center">
      {
        q.nextSteps.map((step) => (
          <a
            href={`${prefix}${step.href}`}
            class="inline-flex items-center px-5 py-3 rounded-lg border-2 border-secondary text-secondary font-semibold hover:bg-secondary/10 transition-colors duration-200"
          >
            {step.label}
          </a>
        ))
      }
    </div>
  </PageSection>
</MainLayout>
