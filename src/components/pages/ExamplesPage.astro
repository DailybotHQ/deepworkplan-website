---
import { getCollection } from 'astro:content';
import Kicker from '@/components/editorial/Kicker.astro';
import Lead from '@/components/editorial/Lead.astro';
import Rule from '@/components/editorial/Rule.astro';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const e = t.examplesPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

const examples = (await getCollection('kit'))
  .filter((entry) => entry.data.lang === lang && entry.data.kind === 'example')
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: e.title,
  itemListElement: examples.map((entry, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: entry.data.title,
    url: `${siteUrl}${prefix}/examples/${slugOf(entry.id)}`,
  })),
};
---

<MainLayout lang={lang} title={e.meta.title} description={e.meta.description}>
  <JsonLd slot="head" data={itemListSchema} />

  <article class="main-container py-16 md:py-24">
    <header class="max-w-3xl">
      <Kicker>{e.eyebrow}</Kicker>
      <h1
        class="font-display mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
        style="color: var(--color-ink);"
      >
        {e.title}
      </h1>
      <Lead class="mt-6">{e.intro}</Lead>
    </header>

    <Rule class="my-12" />

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {
        examples.map((entry) => (
          <a
            href={`${prefix}/examples/${slugOf(entry.id)}`}
            class="group flex flex-col gap-3 border p-6 transition hover:opacity-90"
            style="border-color: var(--color-line);"
          >
            <h2
              class="font-display text-xl font-semibold"
              style="color: var(--color-ink);"
            >
              {entry.data.title}
            </h2>
            <p class="leading-relaxed" style="color: var(--color-muted);">
              {entry.data.description}
            </p>
            <span
              class="kicker mt-auto pt-2"
              style="color: var(--color-secondary);"
            >
              {e.viewExample} &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </article>
</MainLayout>
