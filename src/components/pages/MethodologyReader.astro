---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
  entry: CollectionEntry<'methodology'>;
}

const { lang, entry } = Astro.props;
const t = getTranslations(lang);
const m = t.methodologyPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

const { Content } = await render(entry);

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

const chapters = (await getCollection('methodology'))
  .filter((c) => c.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const index = chapters.findIndex((c) => c.id === entry.id);
const prev = index > 0 ? chapters[index - 1] : null;
const next = index < chapters.length - 1 ? chapters[index + 1] : null;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  url: `${siteUrl}${prefix}/methodology/${slugOf(entry.id)}`,
  isPartOf: { '@type': 'CreativeWork', name: m.title },
};
---

<MainLayout lang={lang} title={entry.data.title} description={entry.data.description}>
  <JsonLd slot="head" data={articleSchema} />
  <article class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl pt-16 pb-20">
    <a
      href={`${prefix}/methodology`}
      class="inline-flex items-center text-sm font-medium text-secondary hover:underline mb-6"
    >
      &larr; {m.backToIndex}
    </a>
    <p class="text-sm font-semibold uppercase tracking-wider text-secondary mb-4">
      {m.chapterLabel} {entry.data.order}
    </p>

    <div class="prose prose-lg prose-slate max-w-none dark:prose-invert prose-headings:scroll-mt-24 prose-a:text-secondary">
      <Content />
    </div>

    <nav
      class="mt-16 pt-8 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row justify-between gap-4"
      aria-label="Chapter"
    >
      {
        prev ? (
          <a
            href={`${prefix}/methodology/${slugOf(prev.id)}`}
            class="group flex-1 rounded-xl border border-gray-200 dark:border-gray-700 p-4 hover:border-secondary transition-colors"
          >
            <span class="text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">
              &larr; {m.prev}
            </span>
            <span class="block font-semibold text-gray-900 dark:text-white group-hover:text-secondary transition-colors">
              {prev.data.title}
            </span>
          </a>
        ) : (
          <span class="flex-1" />
        )
      }
      {
        next ? (
          <a
            href={`${prefix}/methodology/${slugOf(next.id)}`}
            class="group flex-1 rounded-xl border border-gray-200 dark:border-gray-700 p-4 text-right hover:border-secondary transition-colors"
          >
            <span class="text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">
              {m.next} &rarr;
            </span>
            <span class="block font-semibold text-gray-900 dark:text-white group-hover:text-secondary transition-colors">
              {next.data.title}
            </span>
          </a>
        ) : (
          <span class="flex-1" />
        )
      }
    </nav>
  </article>
</MainLayout>
