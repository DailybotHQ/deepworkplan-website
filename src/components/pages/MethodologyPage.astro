---
import { getCollection } from 'astro:content';
import Kicker from '@/components/editorial/Kicker.astro';
import Lead from '@/components/editorial/Lead.astro';
import Rule from '@/components/editorial/Rule.astro';
import JsonLd from '@/components/JsonLd.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const m = t.methodologyPage;
const prefix = getUrlPrefix(lang);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

const chapters = (await getCollection('methodology'))
  .filter((c) => c.data.lang === lang)
  .sort((a, b) => a.data.order - b.data.order);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: m.title,
  itemListElement: chapters.map((ch, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: ch.data.title,
    url: `${siteUrl}${prefix}/methodology/${slugOf(ch.id)}`,
  })),
};
---

<MainLayout lang={lang} title={m.meta.title} description={m.meta.description}>
  <JsonLd slot="head" data={itemListSchema} />

  <article class="main-container py-16 md:py-24">
    <header class="max-w-3xl">
      <Kicker>{m.eyebrow}</Kicker>
      <h1
        class="font-display mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
        style="color: var(--color-ink);"
      >
        {m.title}
      </h1>
      <Lead class="mt-6">{m.intro}</Lead>
    </header>

    <Rule class="my-12" />

    <ol class="space-y-6">
      {
        chapters.map((ch, i) => (
          <li>
            <a
              href={`${prefix}/methodology/${slugOf(ch.id)}`}
              class="group block border p-6 transition hover:opacity-90"
              style="border-color: var(--color-line);"
            >
              <p class="kicker">
                {m.chapterLabel} {String(i + 1).padStart(2, '0')}
              </p>
              <h2
                class="font-display mt-2 text-2xl font-semibold"
                style="color: var(--color-ink);"
              >
                {ch.data.title}
              </h2>
              <p class="mt-2 leading-relaxed" style="color: var(--color-muted);">
                {ch.data.summary ?? ch.data.description}
              </p>
              <span
                class="kicker mt-4"
                style="color: var(--color-secondary);"
              >
                {m.readChapter} &rarr;
              </span>
            </a>
          </li>
        ))
      }
    </ol>
  </article>
</MainLayout>
