---
import { getCollection } from 'astro:content';
import PageHero from '@/components/pages/PageHero.astro';
import PageSection from '@/components/pages/PageSection.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const k = t.kitPage;
const prefix = getUrlPrefix(lang);

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

const entries = (await getCollection('kit')).filter(
  (e) => e.data.lang === lang
);

function byKind(kind: 'command' | 'adapter' | 'preset' | 'example') {
  return entries
    .filter((e) => e.data.kind === kind)
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
}

// Examples have their own gallery page; the kit index covers commands,
// adapters, and presets.
const groups = [
  { meta: k.groups.command, items: byKind('command') },
  { meta: k.groups.adapter, items: byKind('adapter') },
  { meta: k.groups.preset, items: byKind('preset') },
];
---

<MainLayout lang={lang} title={k.meta.title} description={k.meta.description}>
  <PageHero title={k.title} subtitle={k.eyebrow} description={k.intro} />

  {
    groups.map((group, i) => (
      <PageSection
        background={i % 2 === 0 ? 'white' : 'gray'}
        title={group.meta.title}
        description={group.meta.description}
      >
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {group.items.map((entry) => (
            <a
              href={`${prefix}/kit/${slugOf(entry.id)}`}
              class="group flex flex-col gap-2 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800/50 p-5 hover:border-secondary hover:shadow-lg transition-all duration-300"
            >
              <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-secondary transition-colors">
                {entry.data.title}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-300">{entry.data.description}</p>
              <span class="mt-auto pt-2 text-sm font-medium text-secondary">
                {k.viewDetail} &rarr;
              </span>
            </a>
          ))}
        </div>
      </PageSection>
    ))
  }
</MainLayout>
