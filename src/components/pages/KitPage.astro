---
import { getCollection } from 'astro:content';
import Kicker from '@/components/editorial/Kicker.astro';
import Lead from '@/components/editorial/Lead.astro';
import Rule from '@/components/editorial/Rule.astro';
import MainLayout from '@/layouts/MainLayout.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const k = t.kitPage;
const prefix = getUrlPrefix(lang);

function slugOf(id: string): string {
  return id.replace(/^(en|es)\//, '');
}

const entries = (await getCollection('kit')).filter(
  (e) => e.data.lang === lang
);

function byKind(kind: 'command' | 'adapter' | 'preset' | 'example') {
  return entries
    .filter((e) => e.data.kind === kind)
    .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
}

// Examples have their own gallery page; the kit index covers commands,
// adapters, and presets.
const groups = [
  { meta: k.groups.command, items: byKind('command') },
  { meta: k.groups.adapter, items: byKind('adapter') },
  { meta: k.groups.preset, items: byKind('preset') },
];
---

<MainLayout lang={lang} title={k.meta.title} description={k.meta.description}>
  <article class="main-container py-16 md:py-24">
    <header class="max-w-3xl">
      <Kicker>{k.eyebrow}</Kicker>
      <h1
        class="font-display mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
        style="color: var(--color-ink);"
      >
        {k.title}
      </h1>
      <Lead class="mt-6">{k.intro}</Lead>
    </header>

    <Rule class="my-12" />

    <div class="space-y-12">
      {
        groups.map((group) => (
          <section>
            <Kicker>{group.meta.title}</Kicker>
            <p class="mt-3 max-w-3xl leading-relaxed" style="color: var(--color-muted);">
              {group.meta.description}
            </p>
            <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
              {group.items.map((entry) => (
                <a
                  href={`${prefix}/kit/${slugOf(entry.id)}`}
                  class="group flex flex-col gap-2 border p-5 transition hover:opacity-90"
                  style="border-color: var(--color-line);"
                >
                  <h2
                    class="font-display text-base font-semibold"
                    style="color: var(--color-ink);"
                  >
                    {entry.data.title}
                  </h2>
                  <p class="text-sm leading-relaxed" style="color: var(--color-muted);">
                    {entry.data.description}
                  </p>
                  <span
                    class="kicker mt-auto pt-2"
                    style="color: var(--color-secondary);"
                  >
                    {k.viewDetail} &rarr;
                  </span>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </article>
</MainLayout>
