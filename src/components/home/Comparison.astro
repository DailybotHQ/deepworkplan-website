---
import Kicker from '@/components/editorial/Kicker.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const c = t.home.comparison;
---

<section
  class="border-b py-16 md:py-20"
  style="border-color: var(--color-line); background-color: var(--color-gray-100); background-color: color-mix(in srgb, var(--color-ink) 3%, var(--color-paper));"
>
  <div class="main-container">
    <div class="max-w-3xl">
      <Kicker>{c.badge}</Kicker>
      <h2
        class="font-display mt-3 text-3xl font-bold md:text-4xl"
        style="color: var(--color-ink);"
      >
        {c.title}
      </h2>
      <p class="lead mt-4">{c.subtitle}</p>
    </div>
    <div class="mt-10 overflow-x-auto table-responsive">
      <table
        class="w-full border-collapse text-left text-sm nums-tabular"
      >
        <thead>
          <tr class="border-b-2" style="border-color: var(--color-ink);">
            <th class="px-4 py-3"><span class="sr-only">{c.badge}</span></th>
            <th
              class="font-display px-4 py-3 font-semibold"
              style="color: var(--color-secondary);"
            >
              {c.colDwp}
            </th>
            <th
              class="font-display px-4 py-3 font-semibold"
              style="color: var(--color-ink);"
            >
              {c.colOthers}
            </th>
          </tr>
        </thead>
        <tbody>
          {
            c.rows.map((row) => (
              <tr class="border-b" style="border-color: var(--color-line);">
                <th
                  scope="row"
                  class="px-4 py-3 font-semibold"
                  style="color: var(--color-ink);"
                >
                  {row.label}
                </th>
                <td class="px-4 py-3" style="color: var(--color-ink);">
                  {row.dwp}
                </td>
                <td class="px-4 py-3" style="color: var(--color-muted);">
                  {row.others}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
