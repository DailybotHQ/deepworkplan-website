---
import Kicker from '@/components/editorial/Kicker.astro';
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const a = t.home.agents;
---

<section class="border-b py-16 md:py-20" style="border-color: var(--color-line);">
  <div class="main-container">
    <div class="max-w-3xl">
      <Kicker>{a.badge}</Kicker>
      <h2
        class="font-display mt-3 text-3xl font-bold md:text-4xl"
        style="color: var(--color-ink);"
      >
        {a.title}
      </h2>
      <p class="lead mt-4">{a.subtitle}</p>
    </div>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        a.items.map((agent) => (
          <article
            class="border-t pt-4"
            style="border-color: var(--color-line);"
          >
            <div class="flex items-center justify-between gap-2">
              <h3
                class="font-display text-lg font-semibold"
                style="color: var(--color-ink);"
              >
                {agent.name}
              </h3>
              <span
                class="kicker"
                style={`color: ${agent.support === 'full' ? 'var(--color-secondary)' : 'var(--color-muted)'};`}
              >
                {agent.support === 'full' ? a.fullLabel : a.partialLabel}
              </span>
            </div>
            <p class="mt-2 leading-relaxed" style="color: var(--color-muted);">
              {agent.note}
            </p>
          </article>
        ))
      }
    </div>
    <div class="mt-10">
      <a
        href={`${prefix}/kit#adapters`}
        class="inline-flex items-center whitespace-nowrap text-base font-semibold transition hover:opacity-70"
        style="color: var(--color-secondary);"
      >
        {a.viewAllCta} &rarr;
      </a>
    </div>
  </div>
</section>
