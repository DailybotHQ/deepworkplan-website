---
import Kicker from '@/components/editorial/Kicker.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const q = t.home.quickstart;
---

<section
  id="quickstart"
  class="border-b py-16 md:py-20"
  style="border-color: var(--color-line);"
>
  <div class="main-container">
    <div class="max-w-3xl">
      <Kicker>{q.badge}</Kicker>
      <h2
        class="font-display mt-3 text-3xl font-bold md:text-4xl"
        style="color: var(--color-ink);"
      >
        {q.title}
      </h2>
      <p class="lead mt-4">{q.subtitle}</p>
    </div>

    <!-- One path, narrated as a numbered sequence -->
    <ol class="mt-10 grid gap-px sm:grid-cols-2 lg:grid-cols-4">
      {
        q.steps.map((step, i) => (
          <li
            class="flex flex-col gap-3 border p-6"
            style="border-color: var(--color-line);"
          >
            <span
              class="font-display text-3xl font-bold"
              style="color: var(--color-secondary);"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3
              class="font-display text-lg font-semibold"
              style="color: var(--color-ink);"
            >
              {step.title}
            </h3>
            <p class="leading-relaxed" style="color: var(--color-muted);">
              {step.description}
            </p>
          </li>
        ))
      }
    </ol>

    <!-- Install methods, demoted: the instruction handles this for most users -->
    <details class="mt-8 max-w-3xl">
      <summary
        class="cursor-pointer text-base font-semibold transition hover:opacity-80"
        style="color: var(--color-ink);"
      >
        {q.installTitle}
      </summary>
      <p class="mt-3" style="color: var(--color-muted);">{q.installNote}</p>
      <div class="mt-6 grid gap-6 lg:grid-cols-3">
        {
          q.installOptions.map((opt) => (
            <article
              class="flex flex-col gap-3 rounded-sm border p-5"
              style="border-color: var(--color-line);"
            >
              <span class="kicker" style="color: var(--color-muted);">
                {opt.tag}
              </span>
              <h4
                class="font-display text-base font-semibold"
                style="color: var(--color-ink);"
              >
                {opt.title}
              </h4>
              <div
                class="mt-auto overflow-hidden rounded-sm border"
                style="border-color: var(--color-line);"
              >
                <div
                  class="border-b px-3 py-1.5"
                  style="border-color: var(--color-line); background-color: color-mix(in srgb, var(--color-ink) 5%, var(--color-paper));"
                >
                  <span class="kicker" style="color: var(--color-muted);">
                    {q.codeLabel}
                  </span>
                </div>
                <pre
                  class="overflow-x-auto px-3 py-3"
                  style="font-family: var(--font-mono); background-color: color-mix(in srgb, var(--color-ink) 4%, var(--color-paper));"
                ><code class="text-xs leading-relaxed" style="color: var(--color-ink);">{opt.command}</code></pre>
              </div>
              <p class="leading-relaxed" style="color: var(--color-muted);">
                {opt.note}
              </p>
            </article>
          ))
        }
      </div>
    </details>
  </div>
</section>
