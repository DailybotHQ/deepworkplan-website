---
import Kicker from '@/components/editorial/Kicker.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const s = t.home.stacks;
---

<section
  class="border-b py-16 md:py-20"
  style="border-color: var(--color-line); background-color: color-mix(in srgb, var(--color-ink) 3%, var(--color-paper));"
>
  <div class="main-container">
    <div class="max-w-3xl">
      <Kicker>{s.badge}</Kicker>
      <h2
        class="font-display mt-3 text-3xl font-bold md:text-4xl"
        style="color: var(--color-ink);"
      >
        {s.title}
      </h2>
      <p class="lead mt-4">{s.subtitle}</p>
    </div>
    <ul
      class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5"
      role="list"
    >
      {
        s.items.map((stack) => (
          <li
            class="rounded-sm border px-4 py-3"
            style="border-color: var(--color-line);"
          >
            <span
              class="font-display block text-sm font-semibold"
              style="color: var(--color-ink);"
            >
              {stack.name}
            </span>
            <span
              class="block text-xs"
              style="font-family: var(--font-mono); color: var(--color-muted);"
            >
              {stack.sub}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
