---
import Kicker from '@/components/editorial/Kicker.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const a = t.home.archetypes;
const cards = [a.individual, a.orchestrator];
---

<section class="border-b py-16 md:py-20" style="border-color: var(--color-line);">
  <div class="main-container">
    <div class="max-w-3xl">
      <Kicker>{a.badge}</Kicker>
      <h2
        class="font-display mt-3 text-3xl font-bold md:text-4xl"
        style="color: var(--color-ink);"
      >
        {a.title}
      </h2>
      <p class="lead mt-4">{a.subtitle}</p>
    </div>
    <div class="mt-10 grid gap-8 md:grid-cols-2">
      {
        cards.map((card) => (
          <article
            class="border-t pt-4"
            style="border-color: var(--color-line);"
          >
            <span class="kicker" style="color: var(--color-secondary);">
              {card.tag}
            </span>
            <h3
              class="font-display mt-2 text-xl font-semibold"
              style="color: var(--color-ink);"
            >
              {card.title}
            </h3>
            <p class="mt-3 leading-relaxed" style="color: var(--color-muted);">
              {card.description}
            </p>
            <p class="mt-3 italic leading-relaxed" style="color: var(--color-muted);">
              {card.example}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
