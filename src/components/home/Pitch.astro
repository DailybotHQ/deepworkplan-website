---
import Kicker from '@/components/editorial/Kicker.astro';
import Lead from '@/components/editorial/Lead.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const p = t.home.pitch;
---

<section class="border-b py-16 md:py-20" style="border-color: var(--color-line);">
  <div class="main-container">
    <div class="max-w-3xl">
      <Kicker>{p.kicker}</Kicker>
      <div class="mt-6 space-y-5">
        <Lead dropCap>{p.problem}</Lead>
        <div class="py-2">
          <img
            src="/images/visuals/home/pitch-mark.webp"
            alt=""
            width="480"
            height="240"
            loading="lazy"
            class="mx-auto h-auto w-full max-w-[360px] dark:hidden"
          />
          <img
            src="/images/visuals/home/pitch-mark-dark.webp"
            alt=""
            width="480"
            height="240"
            loading="lazy"
            class="mx-auto hidden h-auto w-full max-w-[360px] dark:block"
          />
        </div>
        <p class="text-lg leading-relaxed" style="color: var(--color-ink);">
          {p.answer}
        </p>
        <p class="leading-relaxed" style="color: var(--color-muted);">
          {p.origin}
        </p>
      </div>
    </div>
  </div>
</section>
