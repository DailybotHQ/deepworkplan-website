---
import { type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const p = t.home.pitch;
---

<section class="border-b border-gray-200 py-16 sm:py-20 dark:border-gray-800">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <p class="text-xs font-bold uppercase tracking-widest text-indigo-600 dark:text-indigo-400">
      {p.kicker}
    </p>
    <div class="mt-6 space-y-5">
      <p class="text-lg leading-relaxed text-gray-800 dark:text-gray-100">{p.problem}</p>
      <p class="text-lg leading-relaxed text-gray-800 dark:text-gray-100">{p.answer}</p>
      <p class="text-base leading-relaxed text-gray-600 dark:text-gray-300">{p.origin}</p>
    </div>
  </div>
</section>
