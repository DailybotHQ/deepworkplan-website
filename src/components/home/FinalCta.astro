---
import { getUrlPrefix, type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const f = t.home.finalCta;
---

<section class="relative overflow-hidden border-t border-gray-200 bg-gray-50 py-20 dark:border-gray-800 dark:bg-gray-900">
  <div
    class="pointer-events-none absolute inset-x-0 -top-20 mx-auto h-72 max-w-2xl bg-[radial-gradient(ellipse_at_center,theme(colors.indigo.500/15%),transparent_70%)]"
    aria-hidden="true"
  >
  </div>
  <div class="relative mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-gray-50">
      {f.title}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-gray-600 dark:text-gray-300">
      {f.subtitle}
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a
        href={`${prefix}/methodology`}
        class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-indigo-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400"
      >
        {f.primaryCta}
      </a>
      <a
        href={`${prefix}/spec`}
        class="inline-flex items-center justify-center rounded-lg border border-gray-300 px-5 py-3 text-sm font-semibold text-gray-800 transition-colors hover:border-gray-400 hover:bg-white dark:border-gray-700 dark:text-gray-100 dark:hover:border-gray-600 dark:hover:bg-gray-950"
      >
        {f.secondaryCta}
      </a>
    </div>
    <p class="mt-6 font-mono text-xs text-gray-600 dark:text-gray-300">{f.meta}</p>
  </div>
</section>
