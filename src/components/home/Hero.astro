---
import Kicker from '@/components/editorial/Kicker.astro';
import type { Language } from '@/lib/i18n';
import {
  CANONICAL_INIT_MD_PATH,
  getCanonicalInitMdUrl,
  getUrlPrefix,
} from '@/lib/i18n';
import { getCanonicalInitMarkdown } from '@/lib/init-prompt';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const prefix = getUrlPrefix(lang);
const h = t.home.hero;
// Visible link to the canonical English init.md endpoint shown next to the
// "Copy init.md" button. The href is the env-relative path (resolves to
// localhost in dev, deepworkplan.com in prod); the text is the canonical URL.
const mdHref = CANONICAL_INIT_MD_PATH;
const mdUrl = getCanonicalInitMdUrl(Astro.site?.href);
// The guidance is DISPLAYED in the page language (h.instruction), but the
// "Copy init.md" button copies the full canonical ENGLISH init.md — the literal
// onboarding prompt that works when pasted into an agent (no fetch needed).
const initMarkdown = await getCanonicalInitMarkdown();
---

<section
  class="border-b lg:flex lg:min-h-[calc(100vh-4.5rem)] lg:min-h-[calc(100dvh-4.5rem)] lg:items-center"
  style="border-color: var(--color-line);"
>
  <div class="main-container w-full py-12 lg:py-8">
    <div
      class="lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(0,480px)] lg:items-center lg:gap-10"
    >
      <div class="max-w-3xl">
      <Kicker>{h.badge}</Kicker>
      <h1
        class="font-display mt-4 text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl"
        style="color: var(--color-ink);"
      >
        {h.title}{' '}
        <span style="color: var(--color-secondary);">{h.titleEmphasis}</span>
      </h1>

      <p class="mt-6 max-w-2xl text-lg" style="color: var(--color-ink);">
        {h.subtitle}
      </p>

      <!-- The happy path: one instruction your agent follows -->
      <div
        class="mt-6 overflow-hidden rounded-sm border"
        style="border-color: var(--color-secondary);"
      >
        <div
          class="flex items-center justify-between gap-3 border-b px-4 py-2"
          style="border-color: var(--color-line); background-color: var(--color-gray-100); background-color: color-mix(in srgb, var(--color-ink) 5%, var(--color-paper));"
        >
          <div class="flex min-w-0 flex-col gap-0.5">
            <span class="kicker" style="color: var(--color-muted);"
              >{h.instructionLabel}</span
            >
            <a
              href={mdHref}
              class="break-all font-mono text-xs underline underline-offset-2 transition hover:opacity-80"
              style="color: var(--color-secondary);">{mdUrl}</a
            >
          </div>
          <button
            type="button"
            class="copy-btn kicker inline-flex cursor-pointer items-center gap-1.5 rounded-sm px-2 py-1 transition enabled:hover:opacity-80 disabled:cursor-default disabled:opacity-70"
            style="color: var(--color-secondary);"
            data-copy={initMarkdown}
            data-label={h.copyLabel}
            data-copied={h.copiedLabel}
            data-lang={lang}
            aria-label={h.copyLabel}
          >
            {h.copyLabel}
          </button>
        </div>
        <p
          class="px-4 py-4 text-base leading-relaxed sm:text-lg"
          style="color: var(--color-ink);"
        >
          {h.instruction}
        </p>
      </div>

      <p
        class="font-display mt-6 max-w-2xl border-l-2 pl-4 text-lg italic md:text-xl"
        style="border-color: var(--color-secondary); color: var(--color-ink);"
      >
        {h.pullQuote}
      </p>

      <div
        class="mt-7 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center"
      >
        <a
          href={`${prefix}/init`}
          class="inline-flex items-center justify-center whitespace-nowrap rounded-sm px-6 py-3 text-base font-semibold transition hover:opacity-90"
          style="background-color: var(--color-ink); color: var(--color-paper);"
        >
          {h.viewInitCta}
        </a>
        <a
          href={`${prefix}/methodology`}
          class="inline-flex items-center justify-center whitespace-nowrap rounded-sm border px-6 py-3 text-base font-semibold transition hover:opacity-80"
          style="border-color: var(--color-line); color: var(--color-ink);"
        >
          {h.primaryCta}
        </a>
        <a
          href={`${prefix}/spec`}
          class="inline-flex items-center whitespace-nowrap text-base font-semibold transition hover:opacity-70 sm:px-2"
          style="color: var(--color-secondary);"
        >
          {h.secondaryCta} &rarr;
        </a>
      </div>
      </div>

      <div class="mt-10 hidden md:block lg:mt-0">
        <img
          src="/images/visuals/home/hero-harness.webp"
          alt={h.illustrationAlt}
          width="760"
          height="950"
          class="mx-auto h-auto w-full max-w-[260px] sm:max-w-[340px] lg:max-w-[480px] dark:hidden"
          loading="lazy"
        />
        <img
          src="/images/visuals/home/hero-harness-dark.webp"
          alt={h.illustrationAlt}
          width="760"
          height="950"
          class="mx-auto hidden h-auto w-full max-w-[260px] sm:max-w-[340px] lg:max-w-[480px] dark:block"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { EVENTS, trackEvent } from '@/lib/analytics';

  const COPY_FEEDBACK_MS = 2000;

  // Progressive enhancement: copy the instruction to the clipboard.
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    let busy = false;

    btn.addEventListener('click', async () => {
      if (busy || btn.disabled) return;

      const text = btn.dataset.copy ?? '';
      const label = btn.dataset.label ?? 'Copy';
      const copied = btn.dataset.copied ?? 'Copied';

      busy = true;
      try {
        await navigator.clipboard.writeText(text);
        trackEvent(EVENTS.COPY_INIT, {
          source: 'home',
          lang: btn.dataset.lang ?? 'en',
        });
        btn.disabled = true;
        btn.textContent = copied;
        btn.setAttribute('aria-label', copied);
        window.setTimeout(() => {
          btn.disabled = false;
          btn.textContent = label;
          btn.setAttribute('aria-label', label);
          busy = false;
        }, COPY_FEEDBACK_MS);
      } catch {
        busy = false;
      }
    });
  });
</script>
