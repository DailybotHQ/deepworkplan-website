---
import { type Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const o = t.home.origin;
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <figure
      class="rounded-xl border border-l-4 border-gray-200 border-l-indigo-500 bg-gray-50 p-8 dark:border-gray-800 dark:border-l-indigo-400 dark:bg-gray-900"
    >
      <span class="text-xs font-bold uppercase tracking-widest text-indigo-600 dark:text-indigo-400">
        {o.badge}
      </span>
      <blockquote class="mt-3">
        <p class="text-lg leading-relaxed text-gray-800 dark:text-gray-100">{o.quote}</p>
      </blockquote>
      <figcaption class="mt-4 font-mono text-sm text-gray-600 dark:text-gray-300">
        — {o.attribution}
      </figcaption>
    </figure>
  </div>
</section>
