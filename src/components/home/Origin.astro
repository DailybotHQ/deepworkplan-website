---
import Kicker from '@/components/editorial/Kicker.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const o = t.home.origin;
---

<section class="border-b py-16 md:py-20" style="border-color: var(--color-line);">
  <div class="main-container">
    <figure
      class="max-w-3xl border-l-2 pl-6"
      style="border-color: var(--color-secondary);"
    >
      <Kicker>{o.badge}</Kicker>
      <blockquote class="mt-3">
        <p
          class="font-display text-xl leading-relaxed md:text-2xl"
          style="color: var(--color-ink);"
        >
          {o.quote}
        </p>
      </blockquote>
      <figcaption class="fig-caption mt-4">— {o.attribution}</figcaption>
    </figure>
  </div>
</section>
