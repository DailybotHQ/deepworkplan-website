---
import Kicker from '@/components/editorial/Kicker.astro';
import type { Language } from '@/lib/i18n';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const o = t.home.onboarding;
---

<section
  class="border-b py-16 md:py-20"
  style="border-color: var(--color-line); background-color: color-mix(in srgb, var(--color-ink) 3%, var(--color-paper));"
>
  <div class="main-container">
    <div class="max-w-3xl">
      <Kicker>{o.badge}</Kicker>
      <h2
        class="font-display mt-3 text-3xl font-bold md:text-4xl"
        style="color: var(--color-ink);"
      >
        {o.title}
      </h2>
      <p class="lead mt-4">{o.subtitle}</p>
    </div>
    <ol class="mt-12 grid gap-8 sm:grid-cols-2" role="list">
      {
        o.steps.map((step, i) => (
          <li class="border-t pt-4" style="border-color: var(--color-line);">
            <span
              class="font-display nums-tabular text-3xl font-bold"
              style="color: var(--color-secondary);"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3
              class="font-display mt-3 text-lg font-semibold"
              style="color: var(--color-ink);"
            >
              {step.title}
            </h3>
            <p class="mt-2 leading-relaxed" style="color: var(--color-muted);">
              {step.description}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
