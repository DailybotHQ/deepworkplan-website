const t = i18n[lang as keyof typeof i18n] ?? i18n.en;
---

<figure class={`editorial-asset kitcomp ${className}`} role="img" aria-label={t.ariaLabel}>
  <div class="editorial-asset__grid" aria-hidden="true"></div>
  <div class="editorial-asset__body kitcomp-flow">
    <ul class="kitcomp-sources">
      {t.sources.map((s) => <li class="kitcomp-source">{s}</li>)}
    </ul>
    <span class="kitcomp-arrow ea-accent" aria-hidden="true">→</span>
    <div class="kitcomp-kit ea-accent">{t.kit}</div>
    <span class="kitcomp-arrow" aria-hidden="true">→</span>
    <div class="kitcomp-repo">{t.repo}</div>
  </div>
  <figcaption class="fig-caption">{t.caption}</figcaption>
</figure>

<style>
  .kitcomp {
    color: var(--color-ink);
  }
  .kitcomp-flow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }
  @media (min-width: 720px) {
    .kitcomp-flow {
      flex-direction: row;
      justify-content: center;
    }
  }
  .kitcomp-sources {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .kitcomp-source {
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 0.5rem 0.8rem;
    font-family: var(--font-serif);
    font-size: 0.85rem;
    text-align: center;
    background-color: var(--color-paper);
  }
  .kitcomp-arrow {
    font-size: 1.2rem;
    transform: rotate(90deg);
  }
  @media (min-width: 720px) {
    .kitcomp-arrow {
      transform: none;
    }
  }
  .kitcomp-kit {
    border: 1.5px solid var(--color-secondary);
    border-radius: 6px;
    padding: 0.7rem 1.1rem;
    font-family: var(--font-serif);
    font-weight: 700;
    text-align: center;
  }
  .kitcomp-repo {
    border: 1px solid var(--color-ink);
    border-radius: 6px;
    padding: 0.7rem 1.1rem;
    font-family: var(--font-serif);
    font-weight: 600;
    text-align: center;
  }
</style>
