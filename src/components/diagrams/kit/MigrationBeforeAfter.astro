const t = i18n[lang as keyof typeof i18n] ?? i18n.en;
const tasks = [1, 2, 3, 4, 5];
---

<figure class={`editorial-asset mba ${className}`} role="img" aria-label={t.ariaLabel}>
  <div class="editorial-asset__grid" aria-hidden="true"></div>
  <div class="editorial-asset__body">
    <p class="mba-header ea-label">{t.header}</p>
    <div class="mba-cols">
      <section class="mba-panel">
        <p class="mba-h">{t.withoutTitle}</p>
        <div class="mba-big">
          <span>{t.bigChange}</span>
          <span class="mba-fail ea-accent">✗ {t.fails}</span>
        </div>
      </section>
      <section class="mba-panel">
        <p class="mba-h">{t.withTitle}</p>
        <ol class="mba-tasks">
          {
            tasks.map((n) => (
              <li class="mba-task">
                <span class="mba-check ea-accent" aria-hidden="true">
                  ✓
                </span>
                <span>
                  {t.task} {n}
                </span>
                <span class="mba-gate" aria-hidden="true">
                  ⬡ {t.gate}
                </span>
              </li>
            ))
          }
        </ol>
      </section>
    </div>
  </div>
  <figcaption class="fig-caption">{t.caption}</figcaption>
</figure>

<style>
  .mba {
    color: var(--color-ink);
  }
  .mba-header {
    display: block;
    text-align: center;
    font-size: 0.8rem;
    margin-bottom: 0.85rem;
  }
  .mba-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 600px) {
    .mba-cols {
      grid-template-columns: 1fr 1fr;
    }
  }
  .mba-panel {
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 0.9rem;
    background-color: var(--color-paper);
  }
  .mba-h {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0 0 0.7rem;
  }
  .mba-big {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 8rem;
    border: 1.5px dashed var(--color-line);
    border-radius: 4px;
    font-family: var(--font-serif);
    font-weight: 600;
  }
  .mba-fail {
    font-size: 0.85rem;
    font-weight: 600;
  }
  .mba-tasks {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .mba-task {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-serif);
    font-size: 0.88rem;
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 0.4rem 0.6rem;
  }
  .mba-check {
    font-weight: 700;
  }
  .mba-gate {
    margin-left: auto;
    font-size: 0.72rem;
    color: var(--color-muted);
  }
</style>
