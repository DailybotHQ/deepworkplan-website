const t = i18n[lang as keyof typeof i18n] ?? i18n.en;
---

<figure class={`editorial-asset lifecycle ${className}`} role="img" aria-label={t.ariaLabel}>
  <div class="editorial-asset__grid" aria-hidden="true"></div>
  <div class="editorial-asset__body">
    <span class="ea-label lifecycle-top">{t.communication}</span>
    <ol class="lifecycle-row">
      {
        t.phases.map((p, i) => (
          <li class="lifecycle-phase">
            <span class="lifecycle-name">{p}</span>
            {i < t.phases.length - 1 && (
              <span class="lifecycle-arrow" aria-hidden="true">
                →
              </span>
            )}
          </li>
        ))
      }
    </ol>
    <p class="lifecycle-return ea-accent">↩ {t.returns}</p>
    <div class="lifecycle-safety">
      <span class="ea-label">{t.safety}</span>
      <span class="lifecycle-safety-note">{t.safetyNote}</span>
    </div>
  </div>
  <figcaption class="fig-caption">{t.caption}</figcaption>
</figure>

<style>
  .lifecycle {
    color: var(--color-ink);
  }
  .lifecycle-top {
    display: block;
    font-size: 0.72rem;
    color: var(--color-muted);
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .lifecycle-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.4rem 0.5rem;
  }
  .lifecycle-phase {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem 0.5rem;
  }
  .lifecycle-name {
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 0.4rem 0.7rem;
    font-family: var(--font-serif);
    font-size: 0.9rem;
    background-color: var(--color-paper);
    white-space: nowrap;
  }
  .lifecycle-arrow {
    color: var(--color-muted);
  }
  .lifecycle-return {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.8rem;
    margin: 0.6rem 0 0.85rem;
  }
  .lifecycle-safety {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.6rem;
    border: 1px solid var(--color-secondary);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
  }
  .lifecycle-safety .ea-label {
    color: var(--color-secondary);
    font-size: 0.85rem;
  }
  .lifecycle-safety-note {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--color-muted);
  }
</style>
