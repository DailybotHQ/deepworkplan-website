---
/**
 * CoreLoop — the DWP core loop as an editorial SVG diagram (REFERENCE component).
 *
 * Five operations on a ring (create → execute → refine → resume → status) with
 * verify at the centre. Spec: ME-02 (docs/visuals/prompts/02-methodology.md).
 * Reference implementation for docs/DIAGRAM_COMPONENTS.md — match its patterns.
 *
 * Diagram-as-code: SVG <text> is real, selectable, translatable text driven by an
 * inline language-keyed i18n map with an `en` fallback. Adding a language = adding
 * a key. role="img" + localized aria-label; the SVG is aria-hidden (the label
 * conveys it). Dark mode follows --color-* via currentColor. No JS, no motion.
 */
import type { Language } from '@/lib/i18n';

interface Props {
  lang?: Language;
  class?: string;
}

const { lang = 'en', class: className = '' } = Astro.props;

