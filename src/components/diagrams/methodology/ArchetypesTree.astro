const t = i18n[lang as keyof typeof i18n] ?? i18n.en;
---

<figure class={`editorial-asset arch ${className}`} role="img" aria-label={t.ariaLabel}>
  <div class="editorial-asset__grid" aria-hidden="true"></div>
  <div class="editorial-asset__body">
    <div class="arch-root">{t.root}</div>
    <div class="arch-stem" aria-hidden="true"></div>
    <div class="arch-question">
      <span class="arch-q-mark" aria-hidden="true">?</span>
      <span>{t.question}</span>
    </div>
    <div class="arch-fork" aria-hidden="true">
      <span class="arch-fork-drop"></span>
      <span class="arch-fork-bar"></span>
    </div>
    <div class="arch-branches">
      <div class="arch-branch">
        <span class="arch-leg" aria-hidden="true"></span>
        <span class="ea-label arch-edge arch-edge--no">{t.no}</span>
        <div class="arch-leaf">
          <p class="arch-h">{t.individual}</p>
          <ul class="arch-points">
            {t.indPoints.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      </div>
      <div class="arch-branch">
        <span class="arch-leg" aria-hidden="true"></span>
        <span class="ea-label arch-edge arch-edge--yes">{t.yes}</span>
        <div class="arch-leaf arch-leaf--accent">
          <p class="arch-h">{t.orchestrator}</p>
          <ul class="arch-points">
            {t.orcPoints.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </div>
  <figcaption class="fig-caption">{t.caption}</figcaption>
</figure>

<style>
  .arch {
    color: var(--color-ink);
  }
  .arch-root {
    width: max-content;
    margin: 0 auto;
    border: 1.5px solid var(--color-ink);
    border-radius: 6px;
    padding: 0.45rem 1.4rem;
    font-family: var(--font-serif);
    font-weight: 700;
  }
  .arch-stem {
    width: 1px;
    height: 1rem;
    margin: 0 auto;
    background-color: var(--color-line);
  }
  .arch-question {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: max-content;
    max-width: 100%;
    margin: 0 auto;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.35rem 1rem 0.35rem 0.45rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9rem;
    text-align: left;
  }
  .arch-q-mark {
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
