---
/**
 * ArchetypesCompare (HP-05) — individual repository vs orchestrator hub, compact
 * homepage register. Spec: docs/visuals/prompts/01-homepage.md#hp-05. Each card
 * carries a structural SVG glyph that draws the archetype (a self-contained repo
 * node holding its own files vs. a hub fanning hairline links to child sub-repos)
 * so the contrast reads visually. Language-keyed i18n (en fallback); the SVG is
 * text-light (English file paths only); role="img"; dark mode; zero JS.
 */
import type { Language } from '@/lib/i18n';

interface Props {
  lang?: Language;
  class?: string;
}
const { lang = 'en', class: className = '' } = Astro.props;

const i18n = {
