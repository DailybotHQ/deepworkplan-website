const t = i18n[lang as keyof typeof i18n] ?? i18n.en;
---

<figure class={`editorial-asset acomp ${className}`} role="img" aria-label={t.ariaLabel}>
  <div class="editorial-asset__grid" aria-hidden="true"></div>
  <div class="editorial-asset__body acomp-cols">
    <div class="acomp-card">
      <span class="acomp-mark" aria-hidden="true">▢</span>
      <p class="acomp-h">{t.individual}</p>
      <p class="acomp-sub">{t.individualSub}</p>
    </div>
    <div class="acomp-card acomp-card--accent">
      <span class="acomp-mark ea-accent" aria-hidden="true">⬡⬡⬡</span>
      <p class="acomp-h">{t.orchestrator}</p>
      <p class="acomp-sub">{t.orchestratorSub}</p>
    </div>
  </div>
</figure>

<style>
  .acomp {
    color: var(--color-ink);
  }
  .acomp-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 560px) {
    .acomp-cols {
      grid-template-columns: 1fr 1fr;
    }
  }
  .acomp-card {
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 1rem;
    text-align: center;
    background-color: var(--color-paper);
  }
  .acomp-card--accent {
    border-color: var(--color-secondary);
  }
  .acomp-mark {
    display: block;
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.4rem;
    color: var(--color-muted);
  }
  .acomp-h {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
  }
  .acomp-card--accent .acomp-h {
    color: var(--color-secondary);
  }
  .acomp-sub {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.82rem;
    color: var(--color-muted);
    margin: 0.25rem 0 0;
  }
</style>
