 * skill → adapt your repo → plan & execute. Spec:
 * docs/visuals/prompts/01-homepage.md#hp-03. HTML/CSS; language-keyed i18n (en
 * fallback); role="img"; dark mode; zero JS. (Distinct from the core loop.)
 */
import type { Language } from '@/lib/i18n';

interface Props {
  lang?: Language;
  class?: string;
}
const { lang = 'en', class: className = '' } = Astro.props;

