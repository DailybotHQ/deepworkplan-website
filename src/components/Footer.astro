---
import { REPO_URLS } from '@/lib/constants/repos';
import { getUrlPrefix } from '@/lib/i18n';
import type { Language } from '@/lib/translations';
import { getTranslations } from '@/lib/translations';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;
const t = getTranslations(lang as Language);
const prefix = getUrlPrefix(lang as Language);

const githubUrl = REPO_URLS.website;

const links = [
  { href: `${prefix}/methodology`, label: t.nav.methodology },
  { href: `${prefix}/spec`, label: t.nav.spec },
  { href: `${prefix}/kit`, label: t.nav.kit },
  { href: `${prefix}/examples`, label: t.nav.examples },
  { href: `${prefix}/init`, label: t.nav.init },
  { href: `${prefix}/trust`, label: t.nav.trust },
  { href: `${prefix}/about`, label: t.nav.about },
  { href: `${prefix}/contact`, label: t.nav.contact },
];
---

<footer
  class="bg-paper text-ink dark:bg-main dark:text-white border-t border-line transition-colors duration-300"
  style="padding-bottom: env(safe-area-inset-bottom);"
>
  <div class="main-container py-12">
    <div class="flex flex-col items-center gap-6 text-sm">
      <!-- Footer logo-only treatment (per-mode light/dark). Do not regress. -->
      <a
        href={prefix || '/'}
        class="flex items-center hover:opacity-80 transition-opacity"
        aria-label="Deep Work Plan"
      >
        <img
          class="h-7 w-auto block dark:hidden"
          src="/images/brand/dwp-mark-light.png"
          alt="Deep Work Plan"
          width="270"
          height="160"
          loading="lazy"
        />
        <img
          class="h-7 w-auto hidden dark:block"
          src="/images/brand/dwp-mark-dark.png"
          alt="Deep Work Plan"
          width="270"
          height="160"
          loading="lazy"
        />
      </a>

      <nav
        class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2"
        aria-label="Footer"
      >
        {
          links.map((link) => (
            <a
              href={link.href}
              class="hover:text-secondary transition-colors"
              style="color: var(--color-muted);"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-secondary transition-colors"
          style="color: var(--color-muted);"
        >
          {t.nav.github}
        </a>
        <a
          href="https://opensource.org/licenses/MIT"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-secondary transition-colors"
          style="color: var(--color-muted);"
        >
          MIT
        </a>
      </nav>

      <!-- Engineering as marketing: give Dailybot visibility -->
      <a
        href="https://www.dailybot.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 hover:opacity-80 transition-opacity"
        aria-label={`${t.footer.poweredBy} Dailybot`}
      >
        <span class="kicker" style="color: var(--color-muted);"
          >{t.footer.poweredBy}</span
        >
        <!-- Decorative within this labeled link (localized aria-label conveys the
             purpose). alt="" so the logo doesn't add a token that mismatches the
             localized accessible name (fixes label-content-name-mismatch on /es/). -->
        <img
          class="h-5 w-auto block dark:hidden"
          src="/images/dailybot/logo-horizontal-black.svg"
          alt=""
          width="82"
          height="20"
          loading="lazy"
        />
        <img
          class="h-5 w-auto hidden dark:block"
          src="/images/dailybot/logo-horizontal-white.svg"
          alt=""
          width="82"
          height="20"
          loading="lazy"
        />
      </a>

      <div class="kicker text-center">
        &copy; <span id="copyright-year">{new Date().getFullYear()}</span> Deep Work
        Plan &middot; {t.footer.allRightsReserved}
      </div>
    </div>
  </div>
</footer>
