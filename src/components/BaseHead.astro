---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import JsonLd from '@/components/JsonLd.astro';
import { ANALYTICS, SITE_DESCRIPTION, SITE_TITLE } from '@/lib/constances';
import {
  DEFAULT_LANGUAGE,
  getAlternateUrls,
  getOGLocale,
  getSupportedLanguages,
  getUrlPrefix,
  type Language,
} from '@/lib/i18n';

interface Props {
  title: string;
  description: string;
  image?: string;
  lang?: string;
  keywords?: string[];
  prevPage?: string;
  nextPage?: string;
  ogType?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
  title,
  description,
  image = '/images/og-default.png',
  lang = 'en',
  keywords,
  prevPage,
  nextPage,
  ogType = 'website',
  ogImageWidth = 1200,
  ogImageHeight = 630,
} = Astro.props;
const absoluteImageUrl = new URL(image, Astro.site ?? Astro.url).href;
const imageExtension = image.split('.').pop()?.toLowerCase();
const imageMimeType =
  imageExtension === 'png'
    ? 'image/png'
    : imageExtension === 'jpg' || imageExtension === 'jpeg'
      ? 'image/jpeg'
      : imageExtension === 'webp'
        ? 'image/webp'
        : undefined;

// Compute hreflang URLs for multilingual SEO
const alternateUrls = getAlternateUrls(Astro.url.pathname).map((alt) => ({
  ...alt,
  href: new URL(alt.url, Astro.site).href,
}));
const defaultHref =
  alternateUrls.find((a) => a.lang === DEFAULT_LANGUAGE)?.href ??
  canonicalURL.href;
const currentLocale = getOGLocale(lang as Language);
const alternateLocales = getSupportedLanguages()
  .filter((l) => l !== lang)
  .map((l) => getOGLocale(l));
const langPrefix = getUrlPrefix(lang as Language);
const rssHref = new URL(`${langPrefix}/rss.xml`.replace(/^\//, ''), Astro.site);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={rssHref}
/>
<meta name="generator" content={Astro.generator} />

<!--
	Fonts: the editorial type system uses a self-hosted-free SYSTEM serif stack
	(see --font-serif in global.css) so there is nothing to preload for the
	default face — zero font requests, zero FOUT, no layout shift. If a serif
	woff2 is self-hosted later, add its preload here.
-->

<!-- Header logo preload (prevents alt text flash on navigation) -->
<link
  rel="preload"
  href="/images/brand/dwp-mark-light.png"
  as="image"
  type="image/png"
  media="(prefers-color-scheme: light)"
/>
<link
  rel="preload"
  href="/images/brand/dwp-mark-dark.png"
  as="image"
  type="image/png"
  media="(prefers-color-scheme: dark)"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Hreflang for multilingual SEO -->
{
  alternateUrls.map((alt) => (
    <link rel="alternate" hreflang={alt.lang} href={alt.href} />
  ))
}
<link rel="alternate" hreflang="x-default" href={defaultHref} />

<!-- Search engine verification -->
{
  ANALYTICS.verification.bing && (
    <meta name="msvalidate.01" content={ANALYTICS.verification.bing} />
  )
}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta
  name="keywords"
  content={keywords && keywords.length > 0
    ? keywords.join(", ")
    : "Deep Work Plan, DWP methodology, spec-driven development, AI coding agents, agent harness, agent-pilotable repository, AI-first codebase, validation gates, structured agent execution, deepworkplan"}
/>
<meta name="author" content="Deep Work Plan" />

<!-- Theme color for browser chrome -->
<meta
  name="theme-color"
  content="#f7f4ec"
  media="(prefers-color-scheme: light)"
/>
<meta
  name="theme-color"
  content="#14140f"
  media="(prefers-color-scheme: dark)"
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImageUrl} />
<meta property="og:image:secure_url" content={absoluteImageUrl} />
{imageMimeType && <meta property="og:image:type" content={imageMimeType} />}
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content={String(ogImageWidth)} />
<meta property="og:image:height" content={String(ogImageHeight)} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={currentLocale} />
{
  alternateLocales.map((locale) => (
    <meta property="og:locale:alternate" content={locale} />
  ))
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL.href} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={absoluteImageUrl} />
<meta property="twitter:image:alt" content={title} />

<!-- Pagination SEO -->
{prevPage && <link rel="prev" href={prevPage} />}
{nextPage && <link rel="next" href={nextPage} />}

<!-- JSON-LD: WebSite -->
<JsonLd
  data={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE_TITLE,
    url: Astro.site?.href,
    inLanguage: ["en", "es"],
    description: SITE_DESCRIPTION,
  }}
/>

<!-- JSON-LD: SoftwareApplication (Deep Work Plan) -->
<JsonLd
  data={{
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Deep Work Plan",
    alternateName: "DWP",
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Any",
    url: Astro.site?.href,
    description: SITE_DESCRIPTION,
    isAccessibleForFree: true,
    license: "https://opensource.org/licenses/MIT",
    keywords:
      "spec-driven development, AI coding agents, agent harness, agent-pilotable repository, validation gates, structured agent execution, AI-first codebase",
    featureList: [
      "Spec-driven development: the plan is the durable source of truth",
      "Atomic, independently verifiable tasks with explicit validation gates",
      "Tool-agnostic and repo-native: works with Claude, Cursor, Copilot, Codex, Gemini, and more",
      "Installs the harness into the repository itself (AGENTS.md, docs, .agents/ skills, the DWP skill)",
      "Resumable, version-controlled, Markdown-based plans and running logs",
    ],
    softwareHelp: {
      "@type": "CreativeWork",
      url: new URL("init", Astro.site ?? Astro.url).href,
    },
    codeRepository: "https://github.com/DailybotHQ/deepworkplan-skill",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
    author: {
      "@type": "Organization",
      name: "Dailybot",
      url: "https://www.dailybot.com",
    },
    publisher: {
      "@type": "Organization",
      name: "Dailybot",
      url: "https://www.dailybot.com",
    },
  }}
/>

<!-- JSON-LD: Organization (Dailybot) -->
<JsonLd
  data={{
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "Dailybot",
    url: "https://www.dailybot.com",
    description:
      "AI-powered platform for asynchronous team collaboration; maintainer of the open-source Deep Work Plan methodology.",
    sameAs: [
      "https://twitter.com/dailybotHQ",
      "https://www.linkedin.com/company/dailybot",
      "https://github.com/DailybotHQ",
    ],
  }}
/>

<!-- Analytics: Umami (cookieless, privacy-first) -->
{
  ANALYTICS.umami.websiteId && (
    <script
      is:inline
      defer
      src={ANALYTICS.umami.scriptUrl}
      data-website-id={ANALYTICS.umami.websiteId}
    />
  )
}
