---
import { getCollection } from 'astro:content';
import KitReader from '@/components/pages/KitReader.astro';

export async function getStaticPaths() {
  const entries = await getCollection('kit');
  return entries
    .filter(
      (entry) => entry.data.lang === 'es' && entry.data.kind === 'example'
    )
    .map((entry) => ({
      params: { slug: entry.id.replace(/^es\//, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
---

<KitReader lang="es" entry={entry} variant="examples" />
