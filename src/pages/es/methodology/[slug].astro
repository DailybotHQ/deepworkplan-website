---
import { getCollection } from 'astro:content';
import MethodologyReader from '@/components/pages/MethodologyReader.astro';

export async function getStaticPaths() {
  const entries = await getCollection('methodology');
  return entries
    .filter((entry) => entry.data.lang === 'es')
    .map((entry) => ({
      params: { slug: entry.id.replace(/^es\//, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
---

<MethodologyReader lang="es" entry={entry} />
