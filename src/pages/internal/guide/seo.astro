---
import InternalLayout from '@/layouts/InternalLayout.astro';

const metaTags = [
  {
    tag: 'title',
    source: 'BaseHead.astro',
    description:
      'Page title with site name suffix. Format: "Page Title | Deep Work Plan"',
  },
  {
    tag: 'meta description',
    source: 'BaseHead.astro',
    description:
      'From page translations or content frontmatter. Target: 130-160 characters.',
  },
  {
    tag: 'og:title',
    source: 'BaseHead.astro',
    description: 'Open Graph title for social sharing (Facebook, LinkedIn)',
  },
  {
    tag: 'og:description',
    source: 'BaseHead.astro',
    description: 'Open Graph description for social previews',
  },
  {
    tag: 'og:image',
    source: 'BaseHead.astro',
    description:
      'Social sharing image. Pages use the on-brand default OG card.',
  },
  {
    tag: 'og:type',
    source: 'BaseHead.astro',
    description: '"article" for methodology/spec articles, "website" otherwise',
  },
  {
    tag: 'twitter:card',
    source: 'BaseHead.astro',
    description: 'summary_large_image with the OG card image',
  },
  {
    tag: 'twitter:title',
    source: 'BaseHead.astro',
    description: 'Twitter/X card title',
  },
  {
    tag: 'twitter:description',
    source: 'BaseHead.astro',
    description: 'Twitter/X card description',
  },
];

const jsonLdTypes = [
  {
    type: 'WebSite + Organization',
    usedOn: 'All pages (BaseHead.astro)',
    description:
      'Site-level structured data with name, URL, and publisher Organization',
    schema: 'schema.org/WebSite',
  },
  {
    type: 'Article',
    usedOn: 'Methodology reader pages',
    description:
      'Structured data for methodology articles (title, description, dates)',
    schema: 'schema.org/Article',
  },
  {
    type: 'TechArticle',
    usedOn: 'Spec and kit reader pages',
    description: 'Structured data for specification sections and kit entries',
    schema: 'schema.org/TechArticle',
  },
  {
    type: 'HowTo',
    usedOn: 'Quickstart and /init pages',
    description: 'Step-by-step adoption instructions as HowToStep items',
    schema: 'schema.org/HowTo',
  },
  {
    type: 'BreadcrumbList',
    usedOn: 'Reader pages with breadcrumbs',
    description: 'Navigation breadcrumb trail for search engines',
    schema: 'schema.org/BreadcrumbList',
  },
];

const markdownTwins = [
  {
    htmlPath: '/about',
    mdPath: '/about.md',
    contentPath: 'src/content/pages/{en,es}/about.md',
  },
  {
    htmlPath: '/methodology',
    mdPath: '/methodology.md',
    contentPath: 'src/content/pages/{en,es}/methodology.md',
  },
  {
    htmlPath: '/methodology/{slug}',
    mdPath: '/methodology/{slug}.md',
    contentPath: 'Auto-generated from methodology content',
  },
  {
    htmlPath: '/spec',
    mdPath: '/spec.md',
    contentPath: 'src/content/pages/{en,es}/spec.md',
  },
  {
    htmlPath: '/spec/{slug}',
    mdPath: '/spec/{slug}.md',
    contentPath: 'Auto-generated from spec content',
  },
  {
    htmlPath: '/kit/{slug}',
    mdPath: '/kit/{slug}.md',
    contentPath: 'Auto-generated from kit content',
  },
];

const sitemapRules = [
  {
    rule: 'Auto-generated',
    description:
      'Astro sitemap integration builds sitemap.xml at build time from all pages',
  },
  {
    rule: 'Internal pages excluded',
    description:
      'Pages under /internal/ are filtered out via sitemap configuration',
  },
  {
    rule: 'Markdown twins excluded',
    description: 'The .md agent endpoints are not listed in the sitemap',
  },
  {
    rule: 'Both languages included',
    description:
      'EN and ES versions of every page appear in the sitemap with hreflang',
  },
];

const canonicalRules = [
  {
    feature: 'Canonical URL',
    description:
      'Every page sets <link rel="canonical"> pointing to itself. Prevents duplicate content issues.',
  },
  {
    feature: 'hreflang (EN)',
    description:
      '<link rel="alternate" hreflang="en" href="..."> points to the English version',
  },
  {
    feature: 'hreflang (ES)',
    description:
      '<link rel="alternate" hreflang="es" href="..."> points to the Spanish version',
  },
  {
    feature: 'x-default',
    description:
      '<link rel="alternate" hreflang="x-default" href="..."> points to English as the default',
  },
];

const verificationRules = [
  {
    service: 'Google Search Console',
    method: 'DNS TXT record only',
    notes:
      'Domain property verification. NO meta tags in HTML. Do NOT add PUBLIC_GOOGLE_SITE_VERIFICATION.',
  },
  {
    service: 'Bing Webmaster Tools',
    method: 'Optional env var',
    notes:
      'Meta tag via PUBLIC_BING_SITE_VERIFICATION env var. Only rendered if env var is set.',
  },
];

const keywordsRules = [
  {
    rule: 'Optional keywords prop',
    description:
      'BaseHead.astro accepts an optional keywords array and renders a <meta name="keywords"> tag',
  },
  {
    rule: 'Per-language keywords',
    description: 'EN and ES pages choose keywords appropriate to each language',
  },
  {
    rule: 'String array',
    description:
      'keywords: ["deep work plan", "spec-driven development", "agent harness", "ai-first repo"]',
  },
];
---

<InternalLayout title="SEO & AEO" description="Search engine and AI engine optimization" section="guide" subsection="seo">

  <!-- Meta Tags -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Meta Tags</h2>
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
      All meta tags are rendered by <code class="text-xs">BaseHead.astro</code> inside <code class="text-xs">MainLayout</code>. Pages and reader articles pass title, description, and image props.
    </p>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Tag</th>
              <th class="text-left py-3 px-4 font-semibold">Source</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {metaTags.map((m) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{m.tag}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{m.source}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{m.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- JSON-LD -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">JSON-LD Structured Data</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Type</th>
              <th class="text-left py-3 px-4 font-semibold">Used On</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
              <th class="text-left py-3 px-4 font-semibold">Schema</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {jsonLdTypes.map((j) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{j.type}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{j.usedOn}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{j.description}</td>
                <td class="py-3 px-4"><code class="text-xs">{j.schema}</code></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Markdown Twins (AEO) -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Markdown Twins (AEO)</h2>
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
      Every HTML page has a <code class="text-xs">.md</code> counterpart for AI agents (Answer Engine Optimization). AI crawlers get clean Markdown instead of parsing HTML.
    </p>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">HTML Path</th>
              <th class="text-left py-3 px-4 font-semibold">Markdown Path</th>
              <th class="text-left py-3 px-4 font-semibold">Content Source</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {markdownTwins.map((m) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{m.htmlPath}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{m.mdPath}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{m.contentPath}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-300 mt-3">
      Validate with <code class="text-xs">npm run md:check</code> (warnings) or <code class="text-xs">npm run md:check:strict</code> (errors for CI).
    </p>
  </section>

  <!-- Sitemap -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Sitemap</h2>
    <div class="space-y-4">
      {sitemapRules.map((s) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
          <h3 class="font-semibold mb-1">{s.rule}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-300">{s.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Keywords -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Keywords</h2>
    <div class="space-y-4">
      {keywordsRules.map((k) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
          <h3 class="font-semibold mb-1">{k.rule}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-300">{k.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Canonical URLs -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Canonical URLs & hreflang</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Feature</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {canonicalRules.map((c) => (
              <tr>
                <td class="py-3 px-4 font-medium">{c.feature}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{c.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Verification -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Verification</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Service</th>
              <th class="text-left py-3 px-4 font-semibold">Method</th>
              <th class="text-left py-3 px-4 font-semibold">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {verificationRules.map((v) => (
              <tr>
                <td class="py-3 px-4 font-medium">{v.service}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{v.method}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{v.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

</InternalLayout>
