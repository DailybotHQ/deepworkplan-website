---
import InternalLayout from '@/layouts/InternalLayout.astro';

const collections = [
  {
    name: 'methodology',
    path: 'src/content/methodology/{en,es}/',
    description:
      'Narrative methodology chapters that explain Deep Work Plan, per language',
    fileCount: 'Per language',
  },
  {
    name: 'spec',
    path: 'src/content/spec/{en,es}/',
    description: 'Readable specification split into ordered sections',
    fileCount: 'Per language',
  },
  {
    name: 'kit',
    path: 'src/content/kit/{en,es}/',
    description: 'Kit catalog — commands, adapters, presets, examples, addons',
    fileCount: 'Per language',
  },
  {
    name: 'pages',
    path: 'src/content/pages/{en,es}/',
    description: 'Markdown twins for AI agents — mirrors every HTML page',
    fileCount: 'Per language',
  },
];

const methodologyFields = [
  {
    field: 'title',
    type: 'string',
    required: true,
    description: 'Document title (translated per language)',
  },
  {
    field: 'description',
    type: 'string',
    required: true,
    description: 'Meta description, 130-160 characters',
  },
  {
    field: 'order',
    type: 'number',
    required: true,
    description: 'Sort order within the methodology reader',
  },
  {
    field: 'lang',
    type: "enum('en'|'es')",
    required: true,
    description: 'Language of the document',
  },
  {
    field: 'summary',
    type: 'string',
    required: false,
    description: 'Short summary surfaced in the reader index',
  },
  {
    field: 'icon',
    type: 'string',
    required: false,
    description: 'Optional icon key for the document',
  },
];

const specFields = [
  {
    field: 'title',
    type: 'string',
    required: true,
    description: 'Section title',
  },
  {
    field: 'description',
    type: 'string',
    required: true,
    description: 'Meta description, 130-160 characters',
  },
  {
    field: 'order',
    type: 'number',
    required: true,
    description: 'Sort order within the spec reader',
  },
  {
    field: 'lang',
    type: "enum('en'|'es')",
    required: true,
    description: 'Language of the document',
  },
  {
    field: 'section',
    type: 'string',
    required: false,
    description: 'Optional grouping label for the section',
  },
];

const kitFields = [
  {
    field: 'title',
    type: 'string',
    required: true,
    description: 'Kit entry title',
  },
  {
    field: 'description',
    type: 'string',
    required: true,
    description: 'Meta description, 130-160 characters',
  },
  {
    field: 'kind',
    type: 'enum',
    required: true,
    description: 'command | adapter | preset | example | addon',
  },
  {
    field: 'lang',
    type: "enum('en'|'es')",
    required: true,
    description: 'Language of the document',
  },
  {
    field: 'order',
    type: 'number',
    required: false,
    description: 'Sort order within its kind',
  },
];

const pagesFields = [
  {
    field: 'title',
    type: 'string',
    required: true,
    description: 'Page title for the Markdown twin',
  },
  {
    field: 'description',
    type: 'string',
    required: true,
    description: 'Meta description, 130-160 characters',
  },
  {
    field: 'lastUpdated',
    type: 'date',
    required: false,
    description: 'Last update date (coerced)',
  },
];

const fileNaming = [
  {
    collection: 'methodology',
    pattern: 'slug.md',
    example: 'overview.md',
    notes: 'Slug always in English; same slug for EN and ES',
  },
  {
    collection: 'spec',
    pattern: 'slug.md',
    example: 'task-anatomy.md',
    notes: 'Slug always in English; same slug for EN and ES',
  },
  {
    collection: 'kit',
    pattern: 'slug.md',
    example: 'commit.md',
    notes: 'Slug always in English; same slug for EN and ES',
  },
  {
    collection: 'pages',
    pattern: 'slug.md',
    example: 'about.md',
    notes: 'Mirrors the HTML route it backs',
  },
];

const keyFiles = [
  {
    path: 'src/content.config.ts',
    description: 'All Zod schemas and collection definitions',
  },
  {
    path: 'src/content/methodology/{en,es}/',
    description: 'Methodology chapters per language',
  },
  {
    path: 'src/content/spec/{en,es}/',
    description: 'Specification sections per language',
  },
  {
    path: 'src/content/kit/{en,es}/',
    description: 'Kit catalog entries per language',
  },
  {
    path: 'src/content/pages/{en,es}/',
    description: 'Markdown twins for AI agents per language',
  },
];
---

<InternalLayout title="Content Collections" description="Schemas and structure for all content types" section="guide" subsection="content-collections">

  <!-- Overview -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Overview</h2>
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
      All content uses Astro Content Collections with Zod schemas defined in <code class="text-xs">src/content.config.ts</code>.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {collections.map((c) => (
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4">
          <div class="flex items-baseline justify-between mb-2">
            <h3 class="font-semibold">{c.name}</h3>
            <span class="text-xs px-2 py-0.5 rounded-full bg-secondary/10 text-secondary font-medium">{c.fileCount}</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">{c.description}</p>
          <code class="text-xs">{c.path}</code>
        </div>
      ))}
    </div>
  </section>

  <!-- Methodology Schema -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Methodology Schema</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Field</th>
              <th class="text-left py-3 px-4 font-semibold">Type</th>
              <th class="text-left py-3 px-4 font-semibold">Required</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {methodologyFields.map((f) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{f.field}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{f.type}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.required ? 'Yes' : 'No'}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Spec Schema -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Spec Schema</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Field</th>
              <th class="text-left py-3 px-4 font-semibold">Type</th>
              <th class="text-left py-3 px-4 font-semibold">Required</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {specFields.map((f) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{f.field}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{f.type}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.required ? 'Yes' : 'No'}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Kit Schema -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Kit Schema</h2>
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
      Schema is <code class="text-xs">.loose()</code> — kind-specific fields beyond the base set are allowed for individual kit entries.
    </p>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Field</th>
              <th class="text-left py-3 px-4 font-semibold">Type</th>
              <th class="text-left py-3 px-4 font-semibold">Required</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {kitFields.map((f) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{f.field}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{f.type}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.required ? 'Yes' : 'No'}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Pages Schema -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Pages Schema</h2>
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-4">
      Backs the agent-friendly Markdown endpoints (AEO) — one Markdown twin per HTML route.
    </p>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Field</th>
              <th class="text-left py-3 px-4 font-semibold">Type</th>
              <th class="text-left py-3 px-4 font-semibold">Required</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {pagesFields.map((f) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{f.field}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{f.type}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.required ? 'Yes' : 'No'}</td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- File Naming -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">File Naming</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Collection</th>
              <th class="text-left py-3 px-4 font-semibold">Pattern</th>
              <th class="text-left py-3 px-4 font-semibold">Example</th>
              <th class="text-left py-3 px-4 font-semibold">Notes</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {fileNaming.map((f) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{f.collection}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{f.pattern}</code></td>
                <td class="py-3 px-4"><code class="text-xs">{f.example}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.notes}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Key Files -->
  <section class="mb-12">
    <h2 class="text-xl md:text-2xl font-bold mb-4">Key Files</h2>
    <div class="rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800">
              <th class="text-left py-3 px-4 font-semibold">Path</th>
              <th class="text-left py-3 px-4 font-semibold">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {keyFiles.map((f) => (
              <tr>
                <td class="py-3 px-4"><code class="text-xs font-medium">{f.path}</code></td>
                <td class="py-3 px-4 text-gray-600 dark:text-gray-300">{f.description}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

</InternalLayout>
