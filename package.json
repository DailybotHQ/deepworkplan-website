{
  "name": "deepworkplan-website",
  "description": "Deep Work Plan — the official website for the DWP methodology for planning and executing complex software work with AI coding agents",
  "author": "Dailybot, Inc.",
  "license": "MIT",
  "homepage": "https://deepworkplan.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/DailybotHQ/deepworkplan-website"
  },
  "type": "module",
  "version": "1.0.79",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "prebuild": "node scripts/generate-agent-skills-index.mjs",
    "generate:agent-skills-index": "node scripts/generate-agent-skills-index.mjs",
    "astro": "astro",
    "astro:check": "astro check",
    "astro:preview": "astro preview",
    "biome:check": "biome check",
    "biome:fix": "biome check --write",
    "biome:fix:unsafe": "biome check --write --unsafe",
    "ncu:check": "ncu",
    "ncu:upgrade": "ncu -u",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "images:optimize": "node scripts/optimize-images.mjs",
    "images:webp": "echo 'All images are natively WebP — no generation needed'",
    "md:check": "node scripts/check-md-parity.mjs",
    "md:check:strict": "node scripts/check-md-parity.mjs --strict",
    "i18n:check": "node scripts/i18n/check.mjs",
    "i18n:scaffold": "node scripts/i18n/scaffold-language.mjs",
    "lighthouse": "lhci autorun",
    "lighthouse:full": "lhci autorun --config=lighthouserc.full.cjs",
    "lighthouse:desktop": "lhci autorun --config=lighthouserc.desktop.cjs",
    "lighthouse:desktop:full": "lhci autorun --config=lighthouserc.desktop.full.cjs",
    "release": "bash .github/scripts/prepare_release.sh"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/compiler-rs": "0.3.1",
    "@astrojs/markdown-satteri": "0.3.4",
    "@astrojs/mdx": "7.0.3",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/svelte": "9.0.1",
    "astro": "7.0.8",
    "reveal.js": "^6.0.1",
    "satteri": "0.9.5",
    "svelte": "5.56.4",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@bruits/satteri-wasm32-wasi": "0.9.5",
    "@lhci/cli": "0.15.1",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/svelte": "5.4.2",
    "@vitest/coverage-v8": "4.1.10",
    "happy-dom": "20.10.6",
    "npm-check-updates": "22.2.9",
    "sharp": "0.35.3",
    "vitest": "4.1.10"
  }
}
